SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=your-service-key-here
# URL base do Next.js. O backend sinaliza esta rota após publicar respostas LLM;
# a outbox no Postgres garante entrega eventual se o POST falhar.
FRONTEND_INTERNAL_URL=http://localhost:3000
# Segredo compartilhado apenas entre backend e a rota interna do frontend.
# Use o mesmo valor em AUTO_REVIEW_RECONCILIATION_SECRET no deploy Next.js.
AUTO_REVIEW_RECONCILIATION_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=["http://localhost:3000"]

# Verificação do JWT do Clerk (session token).
# Configure pelo menos UM mecanismo — sem nenhum, as rotas autenticadas
# rejeitam tudo (fail-closed).
#
# CLERK_JWT_AUDIENCE foi REMOVIDA: o session token do Clerk não emite `aud`, e
# quem separa as instâncias passou a ser CLERK_JWT_ISSUER. Se ela ainda estiver
# no seu .env, apague a linha — o pydantic-settings recusa variáveis que não
# correspondem a nenhum campo e o backend não sobe ("Extra inputs are not
# permitted"). O erro não diz que a variável foi removida; esta nota diz.
#
# A política de algoritmo é derivada da config: se CLERK_JWKS_URL está setado,
# SÓ RS256 é aceito (produção); HS256 só vale quando o JWKS está ausente (estado
# de rollback). Isso fecha o downgrade de algoritmo automaticamente.
#
# HS256 (rollback / integração legada Clerk↔Supabase): cole aqui o "JWT Secret"
# do Supabase (Dashboard → Project Settings → API → JWT Settings).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
# RS256 (Clerk como provedor OIDC, mecanismo de produção): URL do JWKS do Clerk.
# CLERK_JWKS_URL=https://<slug>.clerk.accounts.dev/.well-known/jwks.json
# Validação de `iss` — OBRIGATÓRIA junto com CLERK_JWKS_URL: o boot falha se o
# JWKS estiver setado sem ela (main.py). É o issuer que distingue a instância de
# produção da de desenvolvimento; sem ele, um token do tenant errado morre no
# lookup do `kid` e vira 503 "upstream indisponível" em vez de 401.
# CLERK_JWT_ISSUER=https://<slug>.clerk.accounts.dev
# Tolerância (s) para skew de relógio no decode do JWT (default 30).
# JWT_LEEWAY_SECONDS=30

# Documentação da API (/docs, /redoc, /openapi.json). Fechada por padrão
# (fail-safe) — num serviço internet-facing o /openapi.json anônimo vaza o
# schema de todas as rotas. Descomente para ligar o Swagger em dev local.
# ENABLE_DOCS=true

# Orçamento compartilhado entre /api/llm/run e /api/llm/run-field. O contador
# é atômico no Postgres e usa a identidade efetiva do membro por projeto.
# LLM_RATE_LIMIT_REQUESTS=5
# LLM_RATE_LIMIT_WINDOW_SECONDS=60
