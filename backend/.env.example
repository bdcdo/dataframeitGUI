SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=your-service-key-here
CORS_ORIGINS=["http://localhost:3000"]

# Verificação do JWT do Clerk (template "supabase").
# Configure pelo menos UM mecanismo — sem nenhum, as rotas autenticadas
# rejeitam tudo (fail-closed).
#
# HS256 (integração legada Clerk↔Supabase): cole aqui o "JWT Secret" do
# Supabase (Dashboard → Project Settings → API → JWT Settings).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
# RS256 (Clerk como provedor OIDC): URL do JWKS do Clerk.
# CLERK_JWKS_URL=https://<slug>.clerk.accounts.dev/.well-known/jwks.json
# Validações opcionais:
# CLERK_JWT_ISSUER=https://<slug>.clerk.accounts.dev
# CLERK_JWT_AUDIENCE=authenticated
