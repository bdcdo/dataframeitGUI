SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=your-service-key-here
CORS_ORIGINS=["http://localhost:3000"]

# Verificação do JWT do Clerk (template "supabase").
# Configure pelo menos UM mecanismo — sem nenhum, as rotas autenticadas
# rejeitam tudo (fail-closed).
#
# A política de algoritmo é derivada da config: se CLERK_JWKS_URL está setado,
# SÓ RS256 é aceito (produção); HS256 só vale quando o JWKS está ausente (estado
# de rollback). Isso fecha o downgrade de algoritmo automaticamente.
#
# HS256 (rollback / integração legada Clerk↔Supabase): cole aqui o "JWT Secret"
# do Supabase (Dashboard → Project Settings → API → JWT Settings).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
# RS256 (Clerk como provedor OIDC, mecanismo de produção): URL do JWKS do Clerk.
# CLERK_JWKS_URL=https://<slug>.clerk.accounts.dev/.well-known/jwks.json
# Validação de `aud`: vem LIGADA por default com aud="authenticated" (valor do
# template "supabase"). Setar vazio explicitamente desliga a checagem.
# CLERK_JWT_AUDIENCE=authenticated
# Validação opcional de `iss` — RECOMENDADO em produção para amarrar o token ao
# emissor esperado.
# CLERK_JWT_ISSUER=https://<slug>.clerk.accounts.dev
# Tolerância (s) para skew de relógio no decode do JWT (default 30).
# JWT_LEEWAY_SECONDS=30

# Documentação da API (/docs, /redoc, /openapi.json). Fechada por padrão
# (fail-safe) — num serviço internet-facing o /openapi.json anônimo vaza o
# schema de todas as rotas. Descomente para ligar o Swagger em dev local.
# ENABLE_DOCS=true

# Orçamento compartilhado entre /api/llm/run e /api/llm/run-field. O contador
# é atômico no Postgres e usa a identidade efetiva do membro por projeto.
# LLM_RATE_LIMIT_REQUESTS=5
# LLM_RATE_LIMIT_WINDOW_SECONDS=60
