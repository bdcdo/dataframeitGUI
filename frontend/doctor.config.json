{
  "$schema": "https://react.doctor/schema/config.json",
  "ignore": {
    "overrides": [
      {
        "files": [
          "src/actions/**"
        ],
        "rules": [
          "react-doctor/server-auth-actions"
        ]
      },
      {
        "files": [
          "src/components/ui/**"
        ],
        "rules": [
          "react-doctor/only-export-components",
          "react-doctor/no-multi-comp"
        ]
      },
      {
        "files": [
          "src/components/coding/QuestionsPanel.tsx"
        ],
        "rules": [
          "react-doctor/exhaustive-deps"
        ]
      },
      {
        "files": [
          "src/lib/date-parts.ts"
        ],
        "rules": [
          "react-doctor/js-length-check-first"
        ]
      },
      {
        "files": [
          "src/actions/assignments.ts",
          "src/actions/members.ts",
          "src/actions/projects.ts",
          "src/lib/compare-sync.ts"
        ],
        "rules": [
          "react-doctor/supabase-client-owned-authz-field"
        ]
      },
      {
        "files": [
          "src/hooks/useLlmRunProgress.ts"
        ],
        "rules": [
          "react-doctor/effect-needs-cleanup"
        ]
      },
      {
        "files": [
          "src/lib/clerk-sync.ts",
          "src/lib/schema-utils.ts"
        ],
        "rules": [
          "react-doctor/js-set-map-lookups"
        ]
      },
      {
        "files": [
          "src/hooks/useResetOnKeyChange.ts"
        ],
        "rules": [
          "react-doctor/no-prop-callback-in-render"
        ]
      },
      {
        "files": [
          "src/components/compare/ComparePage.tsx"
        ],
        "rules": [
          "react-doctor/no-ref-current-in-render"
        ]
      },
      {
        "files": [
          "supabase/migrations/20260401000000_clerk_user_mapping.sql",
          "supabase/migrations/20260402000000_master_users.sql"
        ],
        "rules": [
          "react-doctor/supabase-table-missing-rls"
        ]
      },
      {
        "files": [
          "src/components/auto-review/AutoReviewJustificationInput.tsx",
          "src/components/compare/ComparisonPanel.tsx"
        ],
        "rules": [
          "react-doctor/no-event-handler"
        ]
      },
      {
        "files": [
          "src/hooks/usePinnedDoc.ts",
          "src/components/compare/useCompareNavigation.ts"
        ],
        "rules": [
          "react-doctor/no-event-handler"
        ]
      },
      {
        "files": [
          "src/hooks/useAutosaveOnExit.ts"
        ],
        "rules": [
          "react-doctor/no-fetch-in-effect"
        ]
      },
      {
        "files": [
          "src/hooks/useDocumentText.ts"
        ],
        "rules": [
          "react-doctor/no-chain-state-updates",
          "react-doctor/no-derived-state"
        ]
      },
      {
        "files": [
          "src/components/assignments/AssignmentTable.tsx",
          "src/components/schema/OptionsEditor.tsx",
          "src/components/schema/ValidationErrorPanel.tsx",
          "src/components/stats/ExportPanel.tsx"
        ],
        "rules": [
          "react-doctor/no-array-index-as-key"
        ]
      },
      {
        "files": [
          "src/app/**/analyze/compare/page.tsx",
          "src/app/**/reviews/comments/page.tsx"
        ],
        "rules": [
          "react-doctor/no-giant-component"
        ]
      }
    ]
  },
  "rules": {
    "react-doctor/js-combine-iterations": "off"
  }
}
