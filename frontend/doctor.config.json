{
  "$schema": "https://react.doctor/schema/config.json",
  "ignore": {
    "overrides": [
      {
        "files": ["src/actions/**"],
        "rules": [
          "react-doctor/server-auth-actions"
        ]
      },
      {
        "files": ["src/components/ui/**"],
        "rules": [
          "react-doctor/only-export-components"
        ]
      }
    ]
  },
  "rules": {
    "react-doctor/js-combine-iterations": "off"
  }
}
