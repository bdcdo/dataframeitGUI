# engines exige Node >=24.10.0 (ver package.json e scripts/worktree-env/
# env-contract.mjs). Sem engine-strict o npm so emite um aviso EBADENGINE, facil
# de perder no meio do install; a violacao so reaparece depois como "parseEnv is
# not a function" no bootstrap ou no carregamento do Playwright, sem relacao
# obvia com a versao do Node. Com engine-strict a instalacao falha na origem.
#
# Este arquivo nao entra na imagem: o Dockerfile copia so package.json e
# package-lock.json, e fixa node:24-alpine — la a versao nao drifta. A unica
# superficie onde ela drifta e a maquina do dev, que e onde este arquivo age.
engine-strict=true

# Janela de defesa contra supply-chain: so instala versao publicada ha mais de 7
# dias (a unidade e DIAS — ver `npm help config`). Complementa o cooldown
# default-days: 7 ja configurado no .github/dependabot.yml, de modo que nenhum PR
# do Dependabot proponha versao que este piso barraria.
#
# Inerte no fluxo normal: `npm ci` instala do lockfile sem reconstruir a arvore,
# e `npm install` com lock satisfeito nao re-resolve. So age ao resolver pacote
# novo do registry, que e exatamente o caso que se quer proteger.
min-release-age=7
