# Credenciais para os smoke tests E2E autenticados (npm run test:e2e).
# Copie para .env.e2e (não versionado) e preencha com usuários reais do
# tenant Clerk de desenvolvimento. Ver issue #107.
#
# CLERK_SECRET_KEY e NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY são lidos de
# .env.local automaticamente — não precisam ser repetidos aqui.

# Usuário com role "coordenador" em algum projeto de teste.
E2E_COORDINATOR_EMAIL=
E2E_COORDINATOR_PASSWORD=

# Usuário com role "membro" (pesquisador) em algum projeto de teste.
E2E_MEMBER_EMAIL=
E2E_MEMBER_PASSWORD=

# Usuário presente na tabela master_users.
E2E_MASTER_EMAIL=
E2E_MASTER_PASSWORD=

# Projeto onde o usuário E2E_MEMBER_* é pesquisador (role "membro", NÃO
# coordenador). Usado pelo config-guard.smoke.spec.ts para verificar que
# pesquisador é redirecionado ao acessar config/* direto. Ver issue #27.
E2E_PROJECT_ID=

# Opcional: URL base se o dev server não estiver em http://localhost:3000.
# E2E_BASE_URL=http://localhost:3000
