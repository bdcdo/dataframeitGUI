{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.10.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:types": "eslint --config eslint.config.typed.mjs",
    "typecheck": "tsc --noEmit",
    "react-doctor": "react-doctor .",
    "react-doctor:diff": "react-doctor . --scope changed --base origin/main",
    "fallow": "fallow",
    "fallow:audit": "fallow audit",
    "scan": "react-scan http://localhost:3000",
    "test": "vitest run",
    "test:db": "npm run test:db:responses-actor && npm run test:db:identity && npm run test:db:clerk-mapping && npm run test:db:auto-review-sync && npm run test:db:atomic-replace && npm run test:db:llm-rate-limit && npm run test:db:member-permissions && npm run test:db:column-guard && npm run test:db:auto-review-concurrency",
    "test:db:responses-actor": "supabase test db supabase/tests/responses_llm_actor_integrity.test.sql --local",
    "test:db:identity": "npm run test:db:psql -- supabase/tests/canonical_project_identity_rls.test.sql",
    "test:db:clerk-mapping": "npm run test:db:psql -- supabase/tests/clerk_mapping_completion.test.sql",
    "test:db:auto-review-sync": "npm run test:db:psql -- supabase/tests/auto_review_assignment_sync.test.sql",
    "test:db:auto-review-concurrency": "npm run test:db:psql -- supabase/tests/auto_review_assignment_concurrency.test.sql",
    "test:db:atomic-replace": "npm run test:db:psql -- supabase/tests/atomic_replace_rpcs.test.sql",
    "test:db:llm-rate-limit": "npm run test:db:psql -- supabase/tests/llm_rate_limit.test.sql",
    "test:db:member-permissions": "npm run test:db:psql -- supabase/tests/member_permission_rpcs.test.sql",
    "test:db:column-guard": "npm run test:db:psql -- supabase/tests/project_members_column_guard.test.sql",
    "test:db:psql": "bash scripts/run-sql-test.sh",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@clerk/localizations": "^4.13.1",
    "@clerk/nextjs": "^7.5.15",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tailwindcss/typography": "^0.5.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.4",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.12.1",
    "sonner": "^2.0.7",
    "spark-md5": "^3.0.2",
    "svix": "^1.96.1",
    "tailwind-merge": "^3.6.0"
  },
  "overrides": {
    "react-is": "$react",
    "postcss": "^8.5.16",
    "monaco-editor": {
      "dompurify": "^3.4.11"
    },
    "exceljs": {
      "uuid": "^11.1.1"
    }
  },
  "devDependencies": {
    "@clerk/testing": "^2.2.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/spark-md5": "^3.0.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "fallow": "3.3.0",
    "jsdom": "^29.1.1",
    "react-doctor": "0.7.3",
    "react-scan": "0.5.7",
    "shadcn": "^4.13.0",
    "supabase": "2.109.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0",
    "typescript-eslint": "8.63.0",
    "vitest": "^4.1.10"
  }
}
